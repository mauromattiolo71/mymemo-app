# Copia questo file in .env.local e compila i valori.
# .env.local NON viene mai caricato su git (vedi .gitignore).

# Supabase (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Stripe (Developers > API keys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price ID dell'abbonamento a 5,99 EUR/anno (Product Catalog > crea Price ricorrente annuale)
STRIPE_PRICE_ID=price_...

# Email dell'account che ha accesso al pannello admin (/admin) per approvare/rifiutare
# i video pubblici. Deve corrispondere all'email con cui quell'account si registra sul sito.
ADMIN_EMAIL=tuo-indirizzo@esempio.com

# Twilio (per l'invio degli SMS di invito in "Share With Your Loved Ones")
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# URL pubblico dell'app, usato per generare i link di invito negli SMS
NEXT_PUBLIC_APP_URL=https://tuo-progetto.vercel.app
